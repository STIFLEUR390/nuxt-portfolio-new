# useSend configuration
# Get your API key at https://app.usesend.com/dev-settings/api-keys
NUXT_USESEND_API_KEY=us_12345

# Verified sender email (must be verified on useSend)
# See https://app.usesend.com/domains
NUXT_FROM_EMAIL=hello@company.com

# Contact form recipient email
NUXT_CONTACT_EMAIL=herold@example.com

# useSend base URL (optional, only for self-hosted)
# NUXT_USESEND_BASE_URL=https://app.usesend.com
